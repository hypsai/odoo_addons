<?xml version="1.0" encoding="UTF-8"?>
<templates id="oql_editor_templates" xml:space="preserve">
    <!-- 提示项模板 -->
    <t t-name="oql_editor.HintItem">
        <div class="oql-hint-item">
            <span class="oql-hint-value">
                <t t-esc="before"/>
                <strong><t t-esc="match"/></strong>
                <t t-esc="after"/>
            </span>
            <span class="oql-hint-description">
                <t t-esc="description"/>
            </span>
        </div>
    </t>
</templates>