<odoo>

    <!-- Inherit ir.model.access form view to add MCP Tool ACL -->
    <record id="ir_access_view_form_inherit_mcp" model="ir.ui.view">
        <field name="name">ir.model.access.view.form.inherit.mcp</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[./field[@name='perm_read']]" position="after">
                <group name="mcp_base" string="MCP Access" colspan="2">
                    <notebook>
                        <page string="Tools">
                            <div class="alert alert-warning" role="alert">
                                <strong>Warning:</strong> MCP tool ACL can expose model methods
                                to external AI agents. Configure permissions carefully.
                            </div>
                            <group col="2">
                                <field name="perm_mcp_base_tool_default_read"
                                       string="Default Usage Access"/>
                                <field name="mcp_base_tac_ids" nolabel="1" colspan="2">
                                    <tree editable="bottom">
                                        <field name="tool_id"
                                               domain="[('model_id', '=', model_id)]"
                                               required="1"/>
                                        <field name="perm_read"/>
                                        <field name="mac_id" invisible="1"/>
                                        <field name="model_id" invisible="1"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
