<odoo>
    <data>
        <record id="view_oql_alias_tree" model="ir.ui.view">
            <field name="name">oql.alias.tree</field>
            <field name="model">oql.alias</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="model_id"/>
                    <field name="line_ids" widget="many2many_tags" readonly="1"/>
                </tree>
            </field>
        </record>

        <record id="view_oql_alias_form" model="ir.ui.view">
            <field name="name">oql.alias.form</field>
            <field name="model">oql.alias</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="model_id"/>
                        </group>
                        <div class="alert alert-info" role="alert">
                            <strong>Path Format:</strong> Three base formats, optionally prefixed with relational field expansion (<code>field_path =&gt;</code>)<br/>
                            • Dot path: <code>partner_id.name</code><br/>
                            • String template: <code>Name is {partner_id.name}</code><br/>
                            • JSON object: <code>{"name": "partner_id.name", "addresses @ address_ids": {"country": "country_id.name"}}</code><br/>
                            <br/>
                            <strong>Examples with expansion:</strong><br/>
                            • <code>address_ids =&gt; country_id.name</code> (expand + dot path)<br/>
                            • <code>address_ids =&gt; "Address: {city}"</code> (expand + string template)
                        </div>
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="alias"/>
                                <field name="path"/>
                                <field name="enable_shorthand"/>
                                <field name="help"/>
                                <field name="is_complex"/>
                            </tree>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_open_oql_alias_tree" model="ir.actions.act_window">
            <field name="name">OQL Aliases</field>
            <field name="res_model">oql.alias</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>