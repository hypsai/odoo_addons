<odoo>
    <data>
        <record id="view_oql_alias_tree" model="ir.ui.view">
            <field name="name">oql.alias.tree</field>
            <field name="model">oql.alias</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="model_id"/>
                    <field name="line_ids" widget="many2many_tags" readonly="1"/>
                </tree>
            </field>
        </record>

        <record id="view_oql_alias_form" model="ir.ui.view">
            <field name="name">oql.alias.form</field>
            <field name="model">oql.alias</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="model_id"/>
                        </group>
                        <div class="alert alert-info" role="alert">
                            <strong>Path Format (3 modes):</strong><br/>
                            • <b>Field:</b> Dot notation - <code>partner_id.name</code><br/>
                            • <b>JMESPath:</b> Query expression - <code>{name: rec.partner_id.name, email: rec.partner_id.email}</code><br/>
                            • <b>Jinja2:</b> Template string - <code>Name is {{ rec.partner_id.name }}</code>
                        </div>
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="alias"/>
                                <field name="mode"/>
                                <field name="path"/>
                                <field name="enable_shorthand"/>
                                <field name="help"/>
                            </tree>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_open_oql_alias_tree" model="ir.actions.act_window">
            <field name="name">OQL Aliases</field>
            <field name="res_model">oql.alias</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>