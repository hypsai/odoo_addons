<odoo>
    <!-- Inherit ir.model.access tree view to add action button -->
    <record id="ir_access_view_tree_edition_inherit_oql" model="ir.ui.view">
        <field name="name">ir.model.access.view.tree.edition.inherit.oql</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_tree_edition"/>
        <field name="arch" type="xml">
            <field name="perm_unlink" position="after">
                <button name="action_open_form_view"
                        type="object" 
                        icon="fa-external-link" 
                        title="Open Access Rights Form"/>
            </field>
        </field>
    </record>

    <!-- Inherit ir.model.access form view to add OQL field-level ACL -->
    <record id="ir_access_view_form_inherit_oql" model="ir.ui.view">
        <field name="name">ir.model.access.view.form.inherit.oql</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[./field[@name='perm_read']]" position="after">
                <group name="oql" string="OQL Access" colspan="2">
                    <notebook colspan="2">
                        <page string="Fields">
                            <div class="alert alert-warning" role="alert">
                                <strong>Warning:</strong> OQL field-level ACL can bypass Odoo's standard access control. Configure permissions carefully.
                            </div>
                            <group col="4">
                                <field name="perm_oql_fac_default_read" string="Default Read Access"/>
                                <field name="perm_oql_fac_default_write" string="Default Write Access"/>
                                <field name="oql_fac_ids" nolabel="1" colspan="4">
                                    <tree editable="bottom">
                                        <field name="field_id"/>
                                        <field name="perm_read"/>
                                        <field name="perm_write"/>

                                        <field name="model_id" invisible="1" column_invisible="1"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                        <page string="Aliases">
                            <div class="alert alert-warning" role="alert">
                                <strong>Warning:</strong> OQL alias ACL can bypass Odoo's standard access control. Configure permissions carefully.
                            </div>
                            <group col="4">
                                <field name="perm_oql_aac_default_read" string="Default Read Access"/>
                                <field name="perm_oql_aac_default_write" string="Default Write Access"/>
                                <field name="oql_aac_ids" nolabel="1" colspan="4">
                                    <tree editable="bottom">
                                        <field name="alias_id"/>
                                        <field name="perm_read"/>
                                        <field name="perm_write"/>

                                        <field name="model_id" invisible="1" column_invisible="1"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </group>
            </xpath>
        </field>
    </record>
</odoo>