<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- OQL Workbench Page Template -->
    <template id="oql_workbench_template" name="OQL Workbench">
        <html lang="en">
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>OQL Workbench</title>
            
            <!-- CodeMirror -->
            <link rel="stylesheet" href="/oql/static/lib/codemirror/lib/codemirror.css"/>
            <link rel="stylesheet" href="/oql/static/lib/codemirror/addon/hint/show-hint.css"/>
            
            <!-- Font Awesome for icons -->
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
            
            <!-- Custom CSS -->
            <link rel="stylesheet" href="/oql/static/src/css/oql_editor.css"/>
            <link rel="stylesheet" href="/oql/static/src/css/oql_workbench.css"/>
            
            <!-- jQuery (required by OQL Editor Core) -->
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            
            <!-- CodeMirror -->
            <script src="/oql/static/lib/codemirror/lib/codemirror.js"></script>
            <script src="/oql/static/lib/codemirror/addon/hint/show-hint.js"></script>
            
            <!-- OQL Syntax Highlighting (must load before oql_editor.js) -->
            <script src="/oql/static/src/js/oql_highlight.js"></script>
            
            <!-- OQL Editor Core -->
            <script src="/oql/static/src/js/oql_editor.js"></script>
            
            <!-- OQL Workbench App -->
            <script src="/oql/static/src/js/oql_workbench_app.js"></script>
        </head>
        <body class="o_oql_workbench">
            <div id="app"></div>
        </body>
        </html>
    </template>
</odoo>
