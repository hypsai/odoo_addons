<odoo>
    <data>
        <record id="view_oql_term_tree" model="ir.ui.view">
            <field name="name">oql.term.list</field>
            <field name="model">oql.term</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="domain_ids" widget="many2many_tags" readonly="1"/>
                </list>
            </field>
        </record>

        <record id="view_oql_term_form" model="ir.ui.view">
            <field name="name">oql.term.form</field>
            <field name="model">oql.term</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="domain_ids">
                                <list editable="bottom">
                                    <field name="model_id"/>
                                    <field name="name"/>
                                    <field name="domain"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_open_oql_term_tree" model="ir.actions.act_window">
            <field name="name">OQL Terms</field>
            <field name="res_model">oql.term</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>